@page "/repo/{*Name}"
@rendermode InteractiveServer
@attribute [Authorize]
@using Hoardr.Web.Ui
@inject RegistryMetadata Meta
@inject RegistryService Registry
@inject AccountService Accounts
@inject NavigationManager Nav

<PageTitle>Hoardr · @Name</PageTitle>

<div class="breadcrumb">
    <a href="/app">Repositories</a> <span class="sep">/</span> <strong>@Name</strong>
</div>

@if (!_allowed)
{
    <div class="empty-state">
        <h2>No access</h2>
        <p class="muted">You don't have pull permission for this repository.</p>
    </div>
}
else
{
    <div class="page-head">
        <div>
            <h1>@Name</h1>
            <p class="muted">@_tags.Count tag@(_tags.Count == 1 ? "" : "s") · @Humanize.Bytes(_stats.TotalBytes) total</p>
        </div>
        @if (_canDelete)
        {
            <button class="btn btn-danger" @onclick="DeleteRepoAsync">Delete repository</button>
        }
    </div>

    @if (_tags.Count == 0)
    {
        <div class="empty-state">
            <h2>No tags</h2>
            <p class="muted">This repository has no tagged images yet.</p>
        </div>
    }
    else
    {
        <div class="card table-card">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Tag</th><th>Digest</th><th>Size</th><th>Pushed</th>
                        @if (_canDelete)
                        {
                            <th class="col-actions"></th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in _tags)
                    {
                        <tr>
                            <td><span class="tag-pill">@t.Name</span></td>
                            <td class="mono muted">@Short(t.Digest)</td>
                            <td>@Humanize.Bytes(t.Size)</td>
                            <td class="muted">@Humanize.Ago(t.PushedAt)</td>
                            @if (_canDelete)
                            {
                                <td class="col-actions">
                                    <button class="btn-icon-danger" title="Delete tag" @onclick="() => DeleteTagAsync(t.Name)">Delete</button>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

<ConfirmDialog @ref="_confirm" />

@code {
    [Parameter] public string Name { get; set; } = "";
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private bool _allowed;
    private bool _canDelete;
    private RepoStats _stats = new("", 0, 0);
    private List<TagView> _tags = [];
    private ConfirmDialog _confirm = default!;

    private record TagView(string Name, Digest Digest, long Size, DateTime PushedAt);

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthState).User;
        var isMaster = user.IsInRole("master");
        var accountId = ulong.Parse(user.FindFirst("account_id")?.Value ?? "0");

        _allowed = isMaster || Accounts.CanPull(accountId, Name);
        _canDelete = isMaster || Accounts.CanDelete(accountId, Name);
        if (!_allowed)
            return;

        Load();
    }

    private void Load()
    {
        _stats = Meta.GetRepoStats(Name);
        _tags = [.. Meta.ListTags(Name)
            .OrderByDescending(t => t.PushedAt)
            .Select(t => new TagView(t.Name, t.ManifestDigest, ManifestSize(t.ManifestDigest), t.PushedAt))];
    }

    private async Task DeleteTagAsync(string tagName)
    {
        if (!_canDelete)
            return;
        var ok = await _confirm.ShowAsync(
            $"Delete tag \"{tagName}\" from {Name}? The image bytes are reclaimed later by garbage collection.",
            "Delete tag", "Delete tag");
        if (!ok)
            return;

        Registry.DeleteManifestReference(Name, tagName);
        Load();
    }

    private async Task DeleteRepoAsync()
    {
        if (!_canDelete)
            return;
        var ok = await _confirm.ShowAsync(
            $"Delete the entire repository \"{Name}\" and all {_tags.Count} tag{(_tags.Count == 1 ? "" : "s")}? " +
            "This cannot be undone; the image bytes are reclaimed later by garbage collection.",
            "Delete repository", "Delete repository");
        if (!ok)
            return;

        Registry.DeleteRepo(Name);
        Nav.NavigateTo("/app");
    }

    private long ManifestSize(Digest manifest)
        => Meta.GetChildren(manifest)
            .Where(c => c.Kind == ManifestChildKind.Blob)
            .Sum(c => Meta.GetBlob(c.Digest)?.Size ?? 0);

    private static string Short(Digest d) => "sha256:" + d.Hex[..12];
}
