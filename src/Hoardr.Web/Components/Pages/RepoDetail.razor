@page "/repo/{*Name}"
@rendermode InteractiveServer
@attribute [Authorize]
@using Hoardr.Web.Ui
@inject RegistryMetadata Meta
@inject RegistryService Registry
@inject AccountService Accounts
@inject RepoSettingsService RepoSettings
@inject NavigationManager Nav

<PageTitle>Hoardr · @Name</PageTitle>

<div class="breadcrumb">
    <a href="/app">Repositories</a> <span class="sep">/</span> <strong>@Name</strong>
</div>

@if (!_allowed)
{
    <div class="empty-state">
        <h2>No access</h2>
        <p class="muted">You don't have pull permission for this repository.</p>
    </div>
}
else
{
    <div class="page-head">
        <div>
            <h1>@Name</h1>
            <p class="muted">@_tags.Count tag@(_tags.Count == 1 ? "" : "s") · @Humanize.Bytes(_stats.TotalBytes) total</p>
        </div>
        @if (_canDelete)
        {
            <button class="btn btn-danger" @onclick="DeleteRepoAsync">Delete repository</button>
        }
    </div>

    @if (_isMaster)
    {
        <div class="card repo-settings">
            <label class="check" title="Allow anyone to pull this repository without logging in">
                <input type="checkbox" checked="@_publicRead" @onchange="e => TogglePublic((bool)e.Value!)" /> Public pull
            </label>
            <label class="check" title="Keep a virtual 'latest' pointing at the most recently pushed tag">
                <input type="checkbox" checked="@_autoLatest" @onchange="e => ToggleAutoLatest((bool)e.Value!)" /> Auto-latest
            </label>
            @if (_settingsMsg is not null) { <span class="form-msg">@_settingsMsg</span> }
        </div>
    }

    @if (_tags.Count == 0)
    {
        <div class="empty-state">
            <h2>No tags</h2>
            <p class="muted">This repository has no tagged images yet.</p>
        </div>
    }
    else
    {
        <div class="card table-card">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Tag</th><th>Digest</th><th>Size</th><th>Pushed</th>
                        @if (_canDelete)
                        {
                            <th class="col-actions"></th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in _tags)
                    {
                        var isLatest = t.Name == "latest";
                        <tr>
                            <td>
                                <span class="tag-pill@(isLatest ? " tag-latest" : "")">@t.Name</span>
                                @if (isLatest)
                                {
                                    <span class="tag-hint" title="@LatestHint">@(_autoLatest ? "auto" : "pointer")</span>
                                }
                            </td>
                            <td class="mono muted">@Short(t.Digest)</td>
                            <td>@Humanize.Bytes(t.Size)</td>
                            <td class="muted">@Humanize.Ago(t.PushedAt)</td>
                            @if (_canDelete)
                            {
                                <td class="col-actions">
                                    @if (t.Id != 0)
                                    {
                                        <button class="btn-icon-danger" title="Delete tag" @onclick="() => DeleteTagAsync(t.Name)">Delete</button>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

<ConfirmDialog @ref="_confirm" />

@code {
    [Parameter] public string Name { get; set; } = "";
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private bool _allowed;
    private bool _canDelete;
    private bool _isMaster;
    private bool _autoLatest;
    private bool _publicRead;
    private string? _settingsMsg;
    private RepoStats _stats = new("", 0, 0);
    private List<TagView> _tags = [];
    private ConfirmDialog _confirm = default!;

    // Id 0 marks the virtual "latest" entry from Registry.ListTags (computed, not a stored tag).
    private record TagView(ulong Id, string Name, Digest Digest, long Size, DateTime PushedAt);

    private string LatestHint => _autoLatest
        ? "Auto-latest is on: every push moves \"latest\" onto the newest image."
        : "Pinned to the top — the \"latest\" tag.";

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthState).User;
        _isMaster = user.IsInRole("master");
        var accountId = ulong.Parse(user.FindFirst("account_id")?.Value ?? "0");

        _allowed = _isMaster || Accounts.CanPull(accountId, Name);
        _canDelete = _isMaster || Accounts.CanDelete(accountId, Name);
        if (!_allowed)
            return;

        Load();
    }

    private void Load()
    {
        _stats = Meta.GetRepoStats(Name);
        _autoLatest = RepoSettings.GetAutoLatest(Name);
        _publicRead = RepoSettings.GetPublicRead(Name);
        // Registry.ListTags injects a virtual "latest" (Id 0) when auto-latest is on.
        // "latest" is always pinned to the top; everything else falls back to newest-first.
        _tags = [.. Registry.ListTags(Name)
            .Select(t => new TagView(t.Id, t.Name, t.ManifestDigest, ManifestSize(t.ManifestDigest), t.PushedAt))
            .OrderByDescending(t => t.Name == "latest")
            .ThenByDescending(t => t.PushedAt)];
    }

    // Per-repo settings (master only). Persisted immediately on toggle, like the old admin table.
    private void TogglePublic(bool enabled)
    {
        RepoSettings.SetPublicRead(Name, enabled);
        _publicRead = enabled;
        _settingsMsg = $"Public pull {(enabled ? "enabled" : "disabled")}.";
    }

    private void ToggleAutoLatest(bool enabled)
    {
        RepoSettings.SetAutoLatest(Name, enabled);
        _settingsMsg = $"Auto-latest {(enabled ? "enabled" : "disabled")}.";
        Load(); // virtual "latest" appears/disappears in the tag list
    }

    private async Task DeleteTagAsync(string tagName)
    {
        if (!_canDelete)
            return;
        var ok = await _confirm.ShowAsync(
            $"Delete tag \"{tagName}\" from {Name}? The image bytes are reclaimed later by garbage collection.",
            "Delete tag", "Delete tag");
        if (!ok)
            return;

        Registry.DeleteManifestReference(Name, tagName);
        Load();
    }

    private async Task DeleteRepoAsync()
    {
        if (!_canDelete)
            return;
        var ok = await _confirm.ShowAsync(
            $"Delete the entire repository \"{Name}\" and all {_tags.Count} tag{(_tags.Count == 1 ? "" : "s")}? " +
            "This cannot be undone; the image bytes are reclaimed later by garbage collection.",
            "Delete repository", "Delete repository");
        if (!ok)
            return;

        Registry.DeleteRepo(Name);
        Nav.NavigateTo("/app");
    }

    private long ManifestSize(Digest manifest)
        => Meta.GetChildren(manifest)
            .Where(c => c.Kind == ManifestChildKind.Blob)
            .Sum(c => Meta.GetBlob(c.Digest)?.Size ?? 0);

    private static string Short(Digest d) => "sha256:" + d.Hex[..12];
}
